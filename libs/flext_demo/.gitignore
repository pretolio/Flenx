# Files and directories created by pub.
**/doc/api/
.dart_tool/
.packages

# Conventional directory for build output.
/build/

# Entrypoints e wiring gerados por `dart run flext:bootstrap`.
# Você só mantém o conteúdo (main.dart, config/, views/, admin_app.dart);
# estes são recriados a partir dele.
lib/main.server.dart
lib/main.client.dart
lib/views/admin/admin_page.dart

# Arquivos GERADOS pelo jaspr_builder (regeneram com `dart run build_runner build`).
# Ficam fora do controle de versão para não poluir o projeto.
lib/**/*.options.dart
lib/**/*.imports.dart
lib/**/*.sync.dart
lib/generated/
web/main.client.dart

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/
**/ios/Flutter/.last_build_id

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
